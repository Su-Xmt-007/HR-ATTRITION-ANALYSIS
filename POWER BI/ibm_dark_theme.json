{
  "name": "IBM HR Dark Theme",
  "dataColors": ["#E24B4A","#10b981","#f59e0b","#2563a8","#fca5a5","#86efac","#fcd34d","#94a3b8"],
  "background": "#1a1a2e",
  "foreground": "#ffffff",
  "tableAccent": "#2563a8",
  "visualStyles": {
    "*": {
      "*": {
        "background": [{"color":{"solid":{"color":"#16213e"}}}],
        "border": [{"show":true,"color":{"solid":{"color":"#2d3748"}}}],
        "title": [{"fontColor":{"solid":{"color":"#94a3b8"}},"fontSize":11,"bold":true}],
        "labels": [{"color":{"solid":{"color":"#cbd5e1"}},"fontSize":10}]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{"fontSize":32,"bold":true,"color":{"solid":{"color":"#ffffff"}}}],
        "categoryLabel": [{"fontSize":11,"color":{"solid":{"color":"#94a3b8"}}}],
        "background": [{"color":{"solid":{"color":"#1e3a5f"}},"transparency":0}]
      }
    },
    "slicer": {
      "*": {
        "background": [{"color":{"solid":{"color":"#2d2d44"}}}],
        "data": [{"fontColor":{"solid":{"color":"#94a3b8"}},"fontSize":10}]
      }
    },
    "barChart": {
      "*": {
        "background": [{"color":{"solid":{"color":"#16213e"}}}],
        "dataLabels": [{"show":true,"color":{"solid":{"color":"#ffffff"}},"fontSize":10}],
        "categoryAxis": [{"show":true,"labelColor":{"solid":{"color":"#cbd5e1"}},"fontSize":10}],
        "valueAxis": [{"show":false}],
        "gridlines": [{"show":false}]
      }
    },
    "lineChart": {
      "*": {
        "background": [{"color":{"solid":{"color":"#16213e"}}}],
        "dataLabels": [{"show":false}],
        "categoryAxis": [{"labelColor":{"solid":{"color":"#64748b"}},"fontSize":8}],
        "valueAxis": [{"labelColor":{"solid":{"color":"#64748b"}},"fontSize":8}],
        "gridlines": [{"show":true,"color":{"solid":{"color":"#2d3748"}}}]
      }
    },
    "donutChart": {
      "*": {
        "background": [{"color":{"solid":{"color":"#16213e"}}}],
        "legend": [{"show":false}]
      }
    },
    "tableEx": {
      "*": {
        "background": [{"color":{"solid":{"color":"#16213e"}}}],
        "header": [{"fontColor":{"solid":{"color":"#64748b"}},"fontSize":9,"bold":true,"backgroundColor":{"solid":{"color":"#0f172a"}}}],
        "values": [{"fontColorPrimary":{"solid":{"color":"#cbd5e1"}},"fontSize":10,"backgroundColorPrimary":{"solid":{"color":"#16213e"}},"backgroundColorSecondary":{"solid":{"color":"#16213e"}}}],
        "grid": [{"gridVertical":false,"gridHorizontal":true,"gridHorizontalColor":{"solid":{"color":"#1e293b"}}}]
      }
    }
  }
}
